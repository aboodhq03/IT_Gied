@model IEnumerable<IT_Gied.Models.Course>
@{
    ViewData["Title"] = "Manage Courses";
}

<div class="container mt-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 12px; background: rgba(40, 167, 69, 0.15); backdrop-filter: blur(10px); color: #28a745;">
            <div class="d-flex align-items-center">
                <i class="fas fa-check-circle me-3 fs-4"></i>
                <div class="fw-semibold">
                    @TempData["Success"]
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 12px; background: rgba(220, 53, 69, 0.15); backdrop-filter: blur(10px); color: #dc3545;">
            <div class="d-flex align-items-center">
                <i class="fas fa-exclamation-circle me-3 fs-4"></i>
                <div class="fw-semibold">
                    @TempData["Error"]
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <h2><i class="fas fa-book text-primary"></i> Course Management</h2>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-success shadow-sm d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#importModal">
                <i class="fas fa-file-upload"></i> Import from File
            </button>
            <a asp-action="CreateCourse" class="btn btn-success shadow-sm d-flex align-items-center gap-2">
                <i class="fas fa-plus"></i> Add New Course
            </a>
        </div>
    </div>

    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item active">Courses</li>
        </ol>
    </nav>

    <div class="glass-panel p-0 overflow-hidden shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Code</th>
                        <th>Course Name</th>
                        <th>Credits</th>
                        <th>Links</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">@course.Code</td>
                            <td>@course.Name</td>
                            <td>@course.CreditHours hrs</td>
                            <td>
                                @if (!string.IsNullOrEmpty(course.DetailsUrl))
                                {
                                    <span class="badge bg-info text-dark" title="AR Link Available">AR</span>
                                }
                                @if (!string.IsNullOrEmpty(course.EDetailsUrl))
                                {
                                    <span class="badge bg-secondary" title="EN Link Available">EN</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="EditCourse" asp-route-id="@course.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <form asp-action="DeleteCourse" asp-route-id="@course.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this course?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Import Modal (نافذة استيراد المساقات) -->
<div class="modal fade" id="importModal" tabindex="-1" aria-labelledby="importModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 18px; background: rgba(30, 35, 45, 0.95); backdrop-filter: blur(15px); color: #fff;">
            <div class="modal-header border-bottom border-secondary border-opacity-20 px-4 py-3">
                <h5 class="modal-title d-flex align-items-center gap-2" id="importModalLabel">
                    <i class="fas fa-file-invoice text-success fs-4"></i>
                    <span>استيراد المساقات من ملف نصي</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <form asp-action="UploadCourses" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-body px-4 py-4" style="max-height: 70vh; overflow-y: auto;">
                    <div class="mb-4">
                        <label for="courseFile" class="form-label fw-semibold mb-2">اختر ملف نصي (.txt, .csv, .json)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-secondary border-0 text-white"><i class="fas fa-file-alt"></i></span>
                            <input type="file" class="form-control bg-dark border-0 text-white" id="courseFile" name="file" accept=".txt,.csv,.json" required style="box-shadow: none;">
                        </div>
                        <div class="form-text text-muted mt-2">ملاحظة: إذا كان كود الكورس مضافاً مسبقاً، سيقوم النظام بتحديث بيانات الكورس تلقائياً بدلاف من تكراره.</div>
                    </div>

                    <hr class="border-secondary border-opacity-20 my-4">

                    <h6 class="fw-bold mb-3 text-warning"><i class="fas fa-info-circle me-1"></i> صيغ الملفات المدعومة:</h6>
                    
                    <div class="accordion" id="formatAccordion" style="border-radius: 12px; overflow: hidden;">
                        
                        <!-- 1. Key-Value Format -->
                        <div class="accordion-item bg-dark border-secondary border-opacity-20 text-white">
                            <h2 class="accordion-header" id="headingOne">
                                <button class="accordion-button bg-dark text-white fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                                    1. صيغة "مفتاح وقيمة" (Key-Value) - الأسهل للملفات النصية البسيطة
                                </button>
                            </h2>
                            <div id="collapseOne" class="accordion-collapse collapse show" aria-labelledby="headingOne" data-bs-parent="#formatAccordion">
                                <div class="accordion-body bg-dark text-white text-start">
                                    <p class="small text-muted">اكتب كل مساق في أسطر متتالية وافصل بين المساقات بـ <code>---</code> أو سطر فارغ. يمكنك كتابة المتطلبات السابقة مفصولة بفاصلة كأكواد المساقات مع إمكانية تحديد نوع العلاقة بين قوسين:</p>
                                    <pre class="bg-secondary bg-opacity-20 p-3 rounded text-info text-start small mb-0" style="direction: ltr; font-family: monospace;">
Code: CS101
Name: Introduction to Programming
CreditHours: 3
Description: Learn basics of programming using Python.
DetailsUrl: https://example.com/ar
EDetailsUrl: https://example.com/en
---
Code: CS102
Name: Object-Oriented Programming
CreditHours: 3
Description: Advanced concepts of OOP.
Prerequisites: CS101 (Prerequisite)</pre>
                                </div>
                            </div>
                        </div>

                        <!-- 2. Pipe-separated Format -->
                        <div class="accordion-item bg-dark border-secondary border-opacity-20 text-white">
                            <h2 class="accordion-header" id="headingTwo">
                                <button class="accordion-button collapsed bg-dark text-white fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                                    2. صيغة الفصل بالعمود (Pipe-separated) أو CSV
                                </button>
                            </h2>
                            <div id="collapseTwo" class="accordion-collapse collapse" aria-labelledby="headingTwo" data-bs-parent="#formatAccordion">
                                <div class="accordion-body bg-dark text-white text-start">
                                    <p class="small text-muted">اكتب كل مساق في سطر واحد وافصل الحقول برمز <code>|</code> أو بفاصلة <code>,</code> بالترتيب التالي:<br>
                                    <code>الكود | الاسم | عدد الساعات | الوصف | رابط التفاصيل بالعربية | رابط التفاصيل بالإنجليزية | المتطلبات السابقة (اختياري)</code></p>
                                    <pre class="bg-secondary bg-opacity-20 p-3 rounded text-info text-start small mb-0" style="direction: ltr; font-family: monospace;">
CS101 | Introduction to Programming | 3 | Introduction course | http://ar | http://en
CS102 | Object-Oriented Programming | 3 | OOP Course | http://ar | http://en | CS101:Prerequisite</pre>
                                </div>
                            </div>
                        </div>

                        <!-- 3. JSON Format -->
                        <div class="accordion-item bg-dark border-secondary border-opacity-20 text-white">
                            <h2 class="accordion-header" id="headingThree">
                                <button class="accordion-button collapsed bg-dark text-white fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
                                    3. صيغة JSON (أكثر دقة للمبرمجين)
                                </button>
                            </h2>
                            <div id="collapseThree" class="accordion-collapse collapse" aria-labelledby="headingThree" data-bs-parent="#formatAccordion">
                                <div class="accordion-body bg-dark text-white text-start">
                                    <p class="small text-muted">مصفوفة كائنات JSON تحتوي على الخصائص المطلوبة مع مصفوفة <code>Prerequisites</code> اختيارية:</p>
                                    <pre class="bg-secondary bg-opacity-20 p-3 rounded text-info text-start small mb-0" style="direction: ltr; font-family: monospace;">
[
  {
    "Code": "CS101",
    "Name": "Introduction to Programming",
    "CreditHours": 3,
    "Description": "Introductory course"
  },
  {
    "Code": "CS102",
    "Name": "Object-Oriented Programming",
    "CreditHours": 3,
    "Description": "OOP course",
    "Prerequisites": [
      { "Code": "CS101", "RelationType": "Prerequisite" }
    ]
  }
]</pre>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                
                <div class="modal-footer border-top border-secondary border-opacity-20 px-4 py-3">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-success px-4"><i class="fas fa-cloud-upload-alt me-1"></i> رفع واستيراد</button>
                </div>
            </form>
        </div>
    </div>
</div>
