@model IEnumerable<IT_Gied.Models.StudentBenefit>
@{
    ViewData["Title"] = "Student Benefits";
}

<div class="container mt-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 12px; background: rgba(40, 167, 69, 0.15); backdrop-filter: blur(10px); color: #28a745;">
            <div class="d-flex align-items-center">
                <i class="fas fa-check-circle me-3 fs-4"></i>
                <div class="fw-semibold">@TempData["Success"]</div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 12px; background: rgba(220, 53, 69, 0.15); backdrop-filter: blur(10px); color: #dc3545;">
            <div class="d-flex align-items-center">
                <i class="fas fa-exclamation-circle me-3 fs-4"></i>
                <div class="fw-semibold">@TempData["Error"]</div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <h2><i class="fas fa-gift text-primary"></i> Student Benefit Management</h2>
        <a asp-action="CreateStudentBenefit" class="btn btn-success shadow-sm d-flex align-items-center gap-2">
            <i class="fas fa-plus"></i> Add New Benefit
        </a>
    </div>

    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item active">Student Benefits</li>
        </ol>
    </nav>

    <div class="glass-panel p-0 overflow-hidden shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Title</th>
                        <th>Provider</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var benefit in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="badge rounded-circle bg-dark text-white d-flex align-items-center justify-content-center" style="width:42px; height:42px;">
                                        <i class="@(string.IsNullOrEmpty(benefit.Icon) ? "fas fa-gift" : benefit.Icon)"></i>
                                    </div>
                                    <div>
                                        <div class="fw-semibold">@benefit.Title</div>
                                        <div class="small text-muted">@benefit.Link</div>
                                    </div>
                                </div>
                            </td>
                            <td>@benefit.ProviderName</td>
                            <td>@benefit.Category</td>
                            <td>
                                <span class="badge @(benefit.IsActive ? "bg-success" : "bg-secondary")">
                                    @(benefit.IsActive ? "Active" : "Disabled")
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="EditStudentBenefit" asp-route-id="@benefit.Id" class="btn btn-sm btn-outline-primary me-1">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <form asp-action="ToggleStudentBenefit" asp-route-id="@benefit.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-warning me-1">
                                        <i class="fas @(benefit.IsActive ? "fa-eye-slash" : "fa-eye")"></i> @(benefit.IsActive ? "Disable" : "Enable")
                                    </button>
                                </form>
                                <form asp-action="DeleteStudentBenefit" asp-route-id="@benefit.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this benefit?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
