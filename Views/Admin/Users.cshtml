@model IEnumerable<ApplicationUser>
@{
    ViewData["Title"] = "User Management";
}

<div class="container mt-5 admin-users-page">
    <div class="glass-panel p-4 mb-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
            <div>
                <h1 class="display-5 text-white mb-2"><i class="fas fa-users text-primary me-2"></i> User Management</h1>
                <p class="text-muted mb-0">View and manage registered users, with quick access to account actions.</p>
            </div>
            <a asp-action="Index" class="btn btn-outline-light">Back to Dashboard</a>
        </div>
    </div>

    <div class="glass-panel admin-card">
        <div class="admin-card-body p-0">
            <table class="table admin-users-table table-hover mb-0">
                <thead class="admin-table-head">
                    <tr>
                        <th>Email</th>
                        <th>User Name</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted">No users found.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>@user.Email</td>
                                <td>@user.UserName</td>
                                <td class="text-end">
                                    <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this user?');" class="d-inline">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
