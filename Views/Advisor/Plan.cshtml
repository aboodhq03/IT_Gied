@model IT_Gied.Models.GraduationPlanViewModel

@{
    ViewData["Title"] = "خطة التخرج الذكية";
}

<div class="container mt-4" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary m-0">
            <i class="fas fa-map-signs"></i> خطة التخرج الذكية
        </h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-right"></i> العودة للترشيحات
        </a>
    </div>

    <div class="row w-100 flex-column align-items-center">
        <div class="col-md-9 mx-auto">
            <div class="card glass-panel border-0 mb-4">
                <div class="card-body p-4">
                    <p class="text-muted mb-4">
                        سيقوم المرشد الأكاديمي الذكي ببناء خطة دراسية متكاملة لك للفصول القادمة، 
                        مع مراعاة معدلك التراكمي (@(Model.GPA?.ToString("0.00") ?? "غير متوفر")) والمقررات التي اجتزتها ومتطلبات المقررات لتضمن تخرجك بسلاسة.
                    </p>

                    <form asp-action="Plan" method="post" id="planForm">
                        <div class="mb-3">
                            <label asp-for="TargetSemesters" class="form-label fw-bold">عدد الفصول الدراسية المستهدفة للخطة</label>
                            <input asp-for="TargetSemesters" type="number" class="form-control" min="1" max="10" value="4" required />
                            <span asp-validation-for="TargetSemesters" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary d-flex align-items-center gap-2" id="submitBtn">
                            <i class="fas fa-magic"></i> إنشاء خطة التخرج
                        </button>
                    </form>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Plan))
            {
                <div class="card glass-panel border-0 shadow-lg animate__animated animate__fadeInUp" style="border-color: rgba(16, 185, 129, 0.3) !important; border-width: 1px !important;">
                    <div class="card-header bg-transparent border-0 text-success d-flex align-items-center gap-2 pt-4 px-4 pb-0">
                        <i class="fas fa-check-circle fs-5"></i>
                        <h5 class="mb-0">الخطة الدراسية المقترحة</h5>
                    </div>
                    <div class="card-body text-end p-4">
                        <p class="mb-0 text-light" style="white-space: pre-line; line-height: 1.8; font-size: 1.05rem;">
                            @Model.Plan
                        </p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('planForm').addEventListener('submit', function() {
            var btn = document.getElementById('submitBtn');
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> جاري إعداد الخطة...';
            btn.disabled = true;
        });
    </script>
}
