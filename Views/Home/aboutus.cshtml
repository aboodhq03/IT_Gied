<link href="~/css/aboutus.css" rel="stylesheet" asp-append-version="true" />

<section class="hero text-start">
    <div class="hero-overlay"></div>

    <div class="container hero-content">
        <div class="row align-items-center">
            <div class="col-lg-6 text-white">
                <h1 class="fw-bold display-5">About Us</h1>
                <h3 class="fw-semibold mt-3 text-light">
                    Empowering IT Students <br> with Guidance
                </h3>
                <p class="mt-3 text-white-50">
                    Learn more about our mission, vision, and what drives us in supporting IT students.
                </p>
            </div>
        </div>
    </div>
</section>

<section class="container about-card-section text-start">
    <div class="card about-card shadow border-0 p-4">
        <div class="row align-items-center g-4">
            <div class="col-lg-6">
                <h4 class="fw-bold text-white">About IT Guide</h4>
                <p class="text-white-50 mt-3">
                    IT Guide is here to guide and assist IT students. We provide clear roadmaps,
                    tailored study plans, and in-depth resources for success in IT disciplines.
                </p>
                <p class="text-white-50">
                    Our platform simplifies learning and helps students stay on track by
                    making complex information accessible and easy to follow.
                </p>
            </div>
            <div class="col-lg-6 text-center">
                <img src="/img/ignup.png" class="img-fluid rounded-4 about-img" alt="About Image">
            </div>
        </div>
    </div>
</section>

<section class="features text-center">
    <div class="container">
        <h2 class="fw-bold text-white">Mission & Vision</h2>
        <p class="text-white-50">Empowering students in their IT journey</p>

        <div class="row mt-4 g-4">
            <div class="col-md-3">
                <div class="feature-box shadow-sm">
                    <i class="bi bi-map fs-1 text-primary"></i> 
                    <h5 class="fw-bold mt-2 text-white">Roadmaps</h5>
                    <p class="text-white-50">Step-by-step guides for IT disciplines.</p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="feature-box shadow-sm">
                    <i class="bi bi-journal-check fs-1 text-secondary"></i>
                    <h5 class="fw-bold mt-2 text-white">Study Plans</h5>
                    <p class="text-white-50">Tailored plans to help students succeed.</p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="feature-box shadow-sm">
                    <i class="bi bi-diagram-3 fs-1 text-accent"></i>
                    <h5 class="fw-bold mt-2 text-white">Departments</h5>
                    <p class="text-white-50">Details about fields and specializations.</p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="feature-box shadow-sm">
                    <i class="bi bi-headset fs-1 text-success"></i>
                    <h5 class="fw-bold mt-2 text-white">Support</h5>
                    <p class="text-white-50">Community and expert advice.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="team text-center mb-5">
    <div class="container">
        <h2 class="fw-bold text-white">Meet Our Team</h2>
        <p class="text-white-50">Passionate and dedicated to your success</p>

        <div class="row mt-4 g-4 justify-content-center">
            <div class="col-md-4">
                <div class="team-card shadow-sm">
                    <img src="/img/abuaqoulah.jpeg" class="team-img" alt="team">
                    <h5 class="fw-bold mt-3 text-white">Abdallah abuaqoulah</h5>
                    <p class="text-white-50">Founder & CEO</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="team-card shadow-sm">
                    <img src="/img/mdalal.jpeg" class="team-img" alt="team">
                    <h5 class="fw-bold mt-3 text-white">abdallah mdalal</h5>
                    <p class="text-white-50">Co-Founder</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="team-card shadow-sm">
                    <img src="/img/batineh.jpeg" class="team-img" alt="team">
                    <h5 class="fw-bold mt-3 text-white">ahmad batineh</h5>
                    <p class="text-white-50">Content Strategist</p>
                </div>
            </div>
        </div>
    </div>
</section>
