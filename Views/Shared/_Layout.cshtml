<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IT Guide</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/IT_Gied.styles.css" asp-append-version="true" />
</head>
<body>
    <canvas id="bg-canvas"></canvas>
    
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark shadow-lg">
            <div class="container-fluid px-lg-5">
                <a class="navbar-brand gradient-text" asp-controller="Home" asp-action="Index">IT Guide</a>
                
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 justify-content-center gap-2">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Departments" asp-action="Index">Departments</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="StudentBenefits" asp-action="Index">Student Benefits</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="aboutus">About Us</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning" asp-controller="Admin" asp-action="Index">
                                    <i class="fas fa-hammer me-1"></i> Admin Dashboard
                                </a>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-3">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            var userData = await UserManager.GetUserAsync(User);
                            var userPart = userData?.Email?.Split('@')[0] ?? "User";
                            var shortName = userPart.Length >= 2 ? $"{userPart[0]}{userPart[^1]}" : userPart;

                            <a class="nav-link p-0 position-relative" asp-action="EditProfile" asp-controller="User">
                                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold border border-2 border-white border-opacity-10"
                                     style="width:42px; height:42px; transition: var(--transition-base);">
                                    @shortName.ToUpper()
                                </div>
                            </a>
                            <a class="btn btn-outline-light btn-sm" asp-action="logout" asp-controller="User">Log out</a>
                        }
                        else
                        {
                            <a class="nav-link" asp-action="Login" asp-controller="User">Log in</a>
                            <a class="btn btn-primary btn-sm px-4" asp-controller="User" asp-action="Register">Sign up</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="main-content">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="container">
            <div class="row g-4 text-start">
                <div class="col-md-4">
                    <h4 class="gradient-text mb-3 text-start">IT Guide</h4>
                    <p class="small text-muted">Your ultimate digital companion for navigating the complex world of information technology academic paths.</p>
                </div>
                <div class="col-md-2 offset-md-2">
                    <h6 class="text-white mb-3">Navigation</h6>
                    <ul class="list-unstyled small">
                        <li><a asp-action="Index" asp-controller="Home" class="text-muted text-decoration-none">Home</a></li>
                        <li><a asp-action="Index" asp-controller="Departments" class="text-muted text-decoration-none">Departments</a></li>
                    </ul>
                </div>
                <div class="col-md-2">
                    <h6 class="text-white mb-3">Support</h6>
                    <ul class="list-unstyled small">
                        <li><a asp-action="aboutus" asp-controller="Home" class="text-muted text-decoration-none">Contact Us</a></li>
                        <li><a asp-action="Privacy" asp-controller="Home" class="text-muted text-decoration-none">Privacy Policy</a></li>
                    </ul>
                </div>
                <div class="col-md-2">
                    <h6 class="text-white mb-3">Follow Us</h6>
                    <div class="d-flex gap-3 fs-5">
                        <a href="#" class="text-muted"><i class="fab fa-x-twitter"></i></a>
                        <a href="#" class="text-muted"><i class="fab fa-linkedin"></i></a>
                        <a href="#" class="text-muted"><i class="fab fa-github"></i></a>
                    </div>
                </div>
            </div>
            <hr class="my-4 opacity-10">
            <div class="text-center small text-muted">
                &copy; 2026 - IT Guide - Built with <i class="fas fa-heart text-danger"></i> for Students
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
