@model IT_Gied.Models.StudentBenefitsPageViewModel
@{
    ViewData["Title"] = "Student Benefits";
}

<link rel="stylesheet" href="~/css/student-benefits.css" asp-append-version="true" />

<div class="student-benefits-hero py-5">
    <div class="container">
        <div class="row align-items-center gy-4">
            <div class="col-lg-7">
                <h1 class="display-5 fw-bold text-white">Student Benefits for University Email Holders</h1>
                <p class="lead text-light opacity-75 mt-3">Discover curated discounts, developer tools, AI credits, and learning platforms designed for students with university credentials.</p>
                <div class="mt-4 d-flex flex-wrap gap-2">
                    @foreach (var category in Model.Categories)
                    {
                        var isActive = string.Equals(category, Model.SelectedCategory, System.StringComparison.OrdinalIgnoreCase);
                        <a asp-action="Index" asp-route-category="@category" class="btn btn-outline-light btn-sm @(isActive ? "active-category" : "")">
                            @category
                        </a>
                    }
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Show All</a>
                </div>
            </div>
            <div class="col-lg-5 text-lg-end">
                <div class="benefits-hero-card p-4 rounded-4 shadow-lg bg-white bg-opacity-10 border border-white border-opacity-10 text-white">
                    <h4 class="mb-3">Why this page matters</h4>
                    <ul class="list-unstyled text-white opacity-80">
                        <li class="mb-2"><i class="fas fa-check-circle text-primary me-2"></i>Verified student-only offers.</li>
                        <li class="mb-2"><i class="fas fa-check-circle text-primary me-2"></i>Developer tools for coding and cloud credits.</li>
                        <li class="mb-2"><i class="fas fa-check-circle text-primary me-2"></i>Learning resources for fast skill growth.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-5">
    <div class="row gy-4">
        @if (!Model.Benefits.Any())
        {
            <div class="col-12">
                <div class="alert alert-secondary border-0 shadow-sm rounded-4" role="alert">
                    No active benefits were found for this category yet. Please check back soon.
                </div>
            </div>
        }

        @foreach (var benefit in Model.Benefits)
        {
            <div class="col-md-6 col-xl-4">
                <div class="benefit-card rounded-4 p-4 h-100">
                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <div class="benefit-icon rounded-circle bg-primary bg-opacity-15 text-primary d-flex align-items-center justify-content-center">
                            <i class="@(string.IsNullOrEmpty(benefit.Icon) ? "fas fa-gift" : benefit.Icon) fa-lg"></i>
                        </div>
                        <span class="badge rounded-pill bg-white bg-opacity-10 text-white text-uppercase small py-2 px-3">@benefit.Category</span>
                    </div>
                    <h4 class="text-white fw-semibold">@benefit.Title</h4>
                    <p class="text-muted small mb-3">Provided by <strong class="text-white">@benefit.ProviderName</strong></p>
                    <p class="text-light opacity-75 mb-4">@benefit.Description</p>
                    <a href="@benefit.Link" target="_blank" class="btn btn-outline-light btn-sm px-4 py-2">
                        Learn More <i class="fas fa-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>
        }
    </div>
</div>
