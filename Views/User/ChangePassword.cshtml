@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    Layout = "_Layout";
}

<!--
    Change Password View - Secure & Professional
    واجهة تغيير كلمة المرور - آمنة واحترافية
-->

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="glass-panel p-4 p-md-5 reveal text-center">
                <div class="d-inline-flex justify-content-center align-items-center bg-primary bg-opacity-10 rounded-circle mb-4 shadow-sm" style="width: 70px; height: 70px;">
                    <i class="fas fa-lock text-primary fs-3"></i>
                </div>
                <h2 class="fw-bold mb-1 gradient-text text-center">Secure Your Account</h2>
                <p class="text-muted small mb-5">Update your password to stay safe</p>

                @if (ViewBag.Success != null)
                {
                    <div class="alert alert-success border-0 shadow-sm mb-4">
                        <i class="fas fa-check-circle me-2"></i> @ViewBag.Success
                    </div>
                }

                <form asp-action="ChangePassword" asp-controller="User" method="post" class="text-start">
                    @Html.AntiForgeryToken()

                    <div class="form-floating mb-3">
                        <input asp-for="CurrentPassword" type="password" class="form-control" placeholder="Current Password" />
                        <label asp-for="CurrentPassword">Current Password</label>
                        <span asp-validation-for="CurrentPassword" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="NewPassword" type="password" class="form-control" placeholder="New Password" />
                        <label asp-for="NewPassword">New Password</label>
                        <span asp-validation-for="NewPassword" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="ConfirmNewPassword" type="password" class="form-control" placeholder="Confirm Password" />
                        <label asp-for="ConfirmNewPassword">Confirm New Password</label>
                        <span asp-validation-for="ConfirmNewPassword" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-4"></div>

                    <div class="d-flex flex-column gap-3">
                        <button type="submit" class="btn btn-primary py-3 fw-bold shadow-lg">
                            Update Password
                        </button>
                        <a asp-action="EditProfile" asp-controller="User" class="btn btn-outline-light py-2 text-center">
                            Back to Profile
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
