@model EditProfileViewModel

@{
    ViewData["Title"] = "Edit Profile";
    Layout = "_Layout";

    var imgPath = string.IsNullOrWhiteSpace(Model.CurrentImageName)
        ? "/images/default-avatar.png"
        : $"/Uplode/Profiles/{Model.CurrentImageName}";
}

<!--
    Edit Profile View - Professional & Clean
    واجهة تعديل الملف الشخصي - احترافية ومنظمة
-->

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="glass-panel p-4 p-md-5 reveal">
                <div class="d-flex align-items-center gap-4 mb-5 border-bottom border-white border-opacity-10 pb-4">
                    <div class="position-relative">
                        <img src="@imgPath"
                             alt="Profile"
                             class="rounded-circle shadow-lg border border-3 border-primary"
                             style="width:120px; height:120px; object-fit:cover;" />
                        <div class="position-absolute bottom-0 end-0 bg-primary rounded-circle p-2 shadow">
                            <i class="fas fa-camera text-white small"></i>
                        </div>
                    </div>
                    <div>
                        <h2 class="fw-bold mb-1 mb-1 gradient-text">Edit Your Profile</h2>
                        <p class="text-muted mb-0 small">Keep your professional information up to date</p>
                    </div>
                </div>

                @if (ViewBag.Success != null)
                {
                    <div class="alert alert-success border-0 shadow-sm mb-4">
                        <i class="fas fa-check-circle me-2"></i> @ViewBag.Success
                    </div>
                }

                <form asp-action="EditProfile" asp-controller="User" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="row g-4">
                        <!-- Profile Image Upload (رفع الصورة) -->
                        <div class="col-12 mb-2">
                             <label class="form-label text-muted small fw-bold">Update Profile Image</label>
                             <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                             <span asp-validation-for="ImageFile" class="text-danger small"></span>
                             <div class="form-text small opacity-50">Upload a professional photo (JPG, PNG).</div>
                        </div>

                        <!-- Email Field (البريد الإلكتروني) -->
                        <div class="col-md-6 form-floating mb-3">
                            <input asp-for="Email" class="form-control" placeholder="Email" />
                            <label asp-for="Email" class="ms-2">Email Address</label>
                            <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <!-- Phone Number (رقم الهاتف) -->
                        <div class="col-md-6 form-floating mb-3">
                            <input asp-for="PhoneNumber" class="form-control" placeholder="Phone" />
                            <label asp-for="PhoneNumber" class="ms-2">Phone Number</label>
                            <span asp-validation-for="PhoneNumber" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-4"></div>

                    <div class="d-flex gap-3 mt-4 pt-4 border-top border-white border-opacity-10">
                        <button type="submit" class="btn btn-primary px-5 py-2 fw-bold">
                            Save Changes
                        </button>
                        <a asp-action="ChangePassword" asp-controller="User" class="btn btn-outline-light px-4 py-2">
                            <i class="fas fa-key me-2"></i> Change Password
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
