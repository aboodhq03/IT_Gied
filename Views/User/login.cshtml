@model LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<!--
    Login View - Modern Clean Design
    واجهة تسجيل الدخول - تصميم عصري ونظيف
-->

<div class="container h-100 d-flex justify-content-center align-items-center py-5">
    <div class="col-12 col-md-8 col-lg-5">
        <div class="card glass-panel border-0 p-4 p-md-5 reveal">
            <div class="text-center mb-5">
                <div class="d-inline-flex justify-content-center align-items-center bg-white bg-opacity-10 rounded-circle mb-3 shadow-lg" style="width: 80px; height: 80px;">
                    <i class="fs-1 bi bi-person-circle text-primary"></i>
                </div>
                <h2 class="fw-bold mb-1 gradient-text">Welcome Back</h2>
                <p class="text-muted">Sign in to continue to IT Guide</p>
            </div>

            <form asp-action="Login" asp-controller="User" method="post">
                @Html.AntiForgeryToken()
                
                <!-- Display Error Messages (إظهار رسائل الخطأ) -->
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 text-center fw-bold"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Email" type="email" class="form-control" placeholder="name@example.com" />
                    <label asp-for="Email">Email Address</label>
                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="form-floating mb-4">
                    <input asp-for="Password" type="password" class="form-control" placeholder="Password" />
                    <label asp-for="Password">Password</label>
                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="RememberMe" class="form-check-input" type="checkbox">
                    <label asp-for="RememberMe" class="form-check-label text-muted small ms-1">
                        Remember me on this device
                    </label>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-3 mb-4 rounded-3 fw-bold fs-5 shadow-lg">
                    Sign In
                </button>

                <p class="text-center text-muted mb-0">
                    Don’t have an account? 
                    <a asp-action="Register" asp-controller="User" class="text-primary fw-bold text-decoration-none border-bottom border-primary pb-1 ms-1">
                        Sign up now
                    </a>
                </p>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
